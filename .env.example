# CranioScan3D environment configuration
# Copy to .env and fill in values

# Path to COLMAP binary (if not in PATH)
COLMAP_BIN=colmap

# Path to OpenMVS binaries directory (if not in PATH)
OPENMVS_BIN_DIR=/usr/local/bin/OpenMVS

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Working directory for pipeline outputs (defaults to data/)
CRANIOSCAN_DATA_DIR=data/
